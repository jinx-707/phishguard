DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/threat_intel
# Application
APP_NAME=Threat Intelligence Platform
APP_VERSION=0.1.0
DEBUG=true
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database - Using PostgreSQL on localhost
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# JWT Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Graph Settings (MVP)
GRAPH_CACHE_TTL=3600

# ML Service
ML_SERVICE_URL=http://localhost:8001
ML_TIMEOUT=30

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=threat-intel-api

# Scoring Weights
MODEL_WEIGHT=0.6
GRAPH_WEIGHT=0.4
