# ============================================================================
# PhishGuard Environment Configuration - EXAMPLE
# ============================================================================
#
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env to version control.
#
# When running with Docker Compose:
#   - Docker Compose overrides these with service names (postgres, redis)
#   - You don't need to modify this file for Docker deployment
#
# When running locally (without Docker):
#   - Use the localhost values below
#   - Ensure PostgreSQL and Redis are running
#   - Start with: uvicorn app.main:app --reload
# ============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Threat Intelligence Platform
APP_VERSION=1.0.0
ENVIRONMENT=development           # development | staging | production
DEBUG=false
API_PREFIX=/api/v1

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── CORS — comma-separated list (use * ONLY in development) ───────────────────
CORS_ORIGINS=*

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=threat_intel
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_postgres_password@localhost:5432/threat_intel
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_at_least_32_characters_long_use_secrets_token_hex
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Fernet Encryption (PII at rest) ──────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to disable (dev only)
FERNET_KEY=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Circuit Breaker (ML service) ──────────────────────────────────────────────
CIRCUIT_BREAKER_FAIL_MAX=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# ── Zero-Day Anomaly Detection ────────────────────────────────────────────────
ZERO_DAY_THRESHOLD=0.60

# ── Graph Settings ────────────────────────────────────────────────────────────
GRAPH_CACHE_TTL=3600
USE_NEO4J=false

# ── Neo4j Production Graph (requires USE_NEO4J=true) ─────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_password

# ── Scoring Weights (MODEL_WEIGHT + GRAPH_WEIGHT should sum to 1.0) ───────────
MODEL_WEIGHT=0.6
GRAPH_WEIGHT=0.4

# ── Risk Decision Thresholds ──────────────────────────────────────────────────
RISK_THRESHOLD_HIGH=0.70
RISK_THRESHOLD_MEDIUM=0.40

# ── Celery Task Queue ─────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── External ML Service (optional — API is fully functional without it) ───────
ML_SERVICE_URL=http://localhost:8001
ML_TIMEOUT=30

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=threat-intel-api

# ── Model Drift Monitoring ────────────────────────────────────────────────────
DRIFT_WINDOW_DAYS=7
DRIFT_P_VALUE=0.05
DRIFT_MIN_SAMPLES=30

# ── Data Retention ────────────────────────────────────────────────────────────
SCAN_RETENTION_DAYS=90

# ── HTML Sanitisation ─────────────────────────────────────────────────────────
ALLOWED_HTML_TAGS=a,b,i,u,em,strong,p,br
