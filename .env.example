# =====================================================
# PHISHGUARD ENVIRONMENT CONFIGURATION
# =====================================================
# Copy this file to .env and modify values
# NEVER commit .env to version control
# =====================================================

# === ENVIRONMENT SELECTION ===
# Options: development | docker | production
ENVIRONMENT=development

# === DATABASE CONFIGURATION ===
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/phishguard
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/phishguard

# === REDIS CONFIGURATION ===
# For local dev: REDIS_HOST=localhost
# For Docker: REDIS_HOST=redis (service name in compose)
# For cloud: REDIS_HOST=your-elasticache-endpoint
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# === CELERY CONFIGURATION ===
# MUST match REDIS_HOST pattern above
# For local: redis://localhost:6379/0
# For Docker: redis://redis:6379/0
# For cloud: redis://your-elasticache:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === THREAT FEEDS ===
# Enable feeds for production intelligence
OPENPHISH_ENABLED=false
OPENPHISH_URL=https://openphish.com/feed.txt

URLHAUS_ENABLED=false
URLHAUS_URL=https://urlhaus.abuse.ch/downloads/json/

PHISHTANK_ENABLED=false
PHISHTANK_URL=https://data.phishtank.org/data/online-valid.json
PHISHTANK_API_KEY=

# === APPLICATION ===
DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# === SECURITY ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string

# === RETENTION ===
SCAN_RETENTION_DAYS=90
GRAPH_REFRESH_INTERVAL=86400
